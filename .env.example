# ============================================================
#  TIPEROUS — Environment Variables
#  Copy to .env.local — NEVER commit .env.local to git
# ============================================================

# ── Supabase ──────────────────────────────────────────────────
# Get from: https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here   # server only, never expose

# ── Google Places API ─────────────────────────────────────────
# Get from: https://console.cloud.google.com → APIs → Places API (New)
NEXT_PUBLIC_GOOGLE_MAPS_KEY=your_google_maps_key_here
GOOGLE_PLACES_API_KEY=your_server_side_places_key_here  # can be same key

# ── App ───────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=Tiperous

# ── Optional: Vercel Analytics ────────────────────────────────
# Auto-injected by Vercel, no action needed
